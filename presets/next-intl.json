{
  "srcDir": "src",
  "locales": ["en"],
  "defaultLocale": "en",
  "filePatterns": ["**/*.{ts,tsx}"],
  "ignore": ["**/*.d.ts", "**/node_modules/**"],
  "hook": {
    "name": "useTranslations",
    "package": "next-intl"
  },
  "layout": {
    "feature": "features/{namespace}/locales/{locale}.json",
    "global": "i18n/messages/{locale}.json",
    "globalNamespace": "common",
    "featuresDir": "features"
  }
}
