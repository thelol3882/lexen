{
  "srcDir": "src",
  "locales": ["en"],
  "defaultLocale": "en",
  "filePatterns": ["**/*.{ts,tsx}"],
  "ignore": ["**/*.d.ts"],
  "hook": [
    {"name": "useTranslations", "package": "next-intl"},
    {"name": "getTranslations", "package": "next-intl/server"}
  ],
  "resolver": {"mode": "typechecker", "propFlow": true},
  "layout": {
    "feature": "features/{namespace}/locales/{locale}.json",
    "widget": "widgets/{widget}/locales/{locale}.json",
    "widgetNamespacePrefix": "widget",
    "global": "i18n/messages/{locale}.json",
    "globalNamespace": "common",
    "featuresDir": "features",
    "widgetsDir": "widgets"
  },
  "calls": [
    {
      "callee": ["buildFixtureMeta"],
      "package": "@test/fixture-seo",
      "arg": 0,
      "namespace": {"prop": "namespace", "default": "common"},
      "keys": ["metadata.${key}.title", "metadata.${key}.description"],
      "defaults": {"key": "root"}
    },
    {
      "callee": ["buildRootFixtureMeta"],
      "package": "@test/fixture-seo",
      "arg": 0,
      "namespace": {"prop": "namespace", "default": "common"},
      "keys": ["metadata.${key}.title", "metadata.${key}.description"],
      "defaults": {"key": "root"}
    }
  ]
}
